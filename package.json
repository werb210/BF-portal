{
  "name": "staff-portal",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "dev:full": "npm run verify:server && vite",
    "build": "npm run guard:single-api && npm run test:e2e && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.tests.json",
    "lint": "eslint .",
    "guard:api-contract": "bash ./scripts/api-guard-checks.sh",
    "verify": "npm run typecheck && npm run build",
    "check": "npm run typecheck",
    "check:portal-api": "bash ./scripts/portal-final-api-check.sh",
    "audit:enterprise": "node scripts/enterprise-audit.js",
    "optimize:images": "node scripts/optimize-images.js",
    "prestart": "node ./scripts/verify-node-version.js",
    "smoke": "node ./scripts/smoke-test.js",
    "test:unit": "vitest run",
    "test:ci": "npm run typecheck && npm run lint && npm run test:unit && npm run test:contracts && npm run guard:api-contract",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "e2e": "playwright test --pass-with-no-tests",
    "test:contracts": "vitest run src/__tests__/authTelephony.flow.test.ts",
    "system:boot": "bash ./scripts/full-system-boot.sh",
    "guard:single-api": "bash ./scripts/enforce-api-pipeline.sh",
    "verify:server": "node -e \"process.exit(0)\"",
    "verify:no-node-fetch": "npm ls node-fetch || exit 0",
    "guard:test-env-regressions": "bash ./scripts/guard-test-env-regressions.sh",
    "verify:test-env-empty": "test ! -s .env.test",
    "verify:no-node-only": "rg -n \"(from|require\\()\\s*[\\\"\\'](node-fetch|fs|path|net|tls)[\\\"\\']\" src && exit 1 || exit 0",
    "verify:no-alt-api": "rg -n \"fetch\\(|axios\\(\" src | rg -v \"apiClient.ts\" && exit 1 || exit 0",
    "verify:no-silent-catch": "rg -n \"catch \\(.*\\) \\{\\s*(return|console)\" src && exit 1 || exit 0",
    "verify:single-api": "rg -n \"(core/apiClient|apiRequest|apiCall|fetch\\()\" src | rg -v \"src/lib/apiClient.ts\" && exit 1 || exit 0"
  },
  "dependencies": {
    "@azure/msal-browser": "^3.30.0",
    "@capacitor/core": "^8.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@tanstack/react-query": "^5.59.19",
    "@tanstack/react-virtual": "^3.13.21",
    "@twilio/voice-sdk": "latest",
    "clsx": "^2.1.1",
    "jwt-decode": "^4.0.0",
    "openai": "^6.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.0.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.7.0",
    "semver": "^7.7.4",
    "socket.io-client": "^4.8.3",
    "twilio-client": "^1.15.1",
    "uuid": "^13.0.0",
    "workbox-window": "^7.4.0",
    "ws": "^8.19.0",
    "zod": "^3.24.0",
    "zustand": "^4.5.5"
  },
  "overrides": {
    "@remix-run/router": "^1.17.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.5.0",
    "@esbuild/linux-x64": "^0.21.5",
    "@playwright/test": "^1.58.2",
    "@rollup/rollup-linux-x64-gnu": "^4.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "depcheck": "^1.4.7",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^24.0.0",
    "madge": "^8.0.0",
    "msw": "^2.12.13",
    "npm-check-updates": "^19.3.2",
    "playwright": "^1.58.2",
    "postcss": "^8.4.47",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.14",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^1.0.0"
  }
}
